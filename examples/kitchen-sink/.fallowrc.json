{
	"$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
	"entry": [
		"aero.config.ts",
		"vite.config.ts",
		"content.config.ts",
		"nitro.config.ts",
		"server/entry.ts",
		"client/pages/**/*.html",
		"client/layouts/*.html",
		"client/components/**/*.html",
		"client/assets/**/*.ts",
		"client/assets/**/*.css",
		"client/assets/**/*.js",
		"public/**/*.js",
		"server/**/*.ts",
		"content/**/*.ts",
		"lib/**/*.ts",
		"server/plugins/**/*.ts",
		"server/tasks/**/*.ts"
	],
	"ignorePatterns": [".output/**", ".nitro/**", ".aero/**", ".vite/**", "dist/**"],
	"ignoreDependencies": [
		"@aero-js/cli",
		"@aero-js/content",
		"@aero-js/core",
		"@aero-js/highlight",
		"autoprefixer",
		"shiki"
	]
}
