{
	"extends": ["../../tsconfig.app.json", "nitro/tsconfig"],
	"compilerOptions": {
		"baseUrl": "./",
		"paths": {
			"@pages/*": ["frontend/pages/*"],
			"@layouts/*": ["frontend/layouts/*"],
