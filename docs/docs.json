{
	"$schema": "https://mintlify.com/docs.json",
	"name": "Aero",
	"theme": "maple",
	"colors": {
		"primary": "#fa8072",
		"light": "#fa8072",
		"dark": "#fa8072"
	},
	"navbar": {
		"primary": {
			"type": "github",
			"href": "https://github.com/jamiewilson/aero"
		}
	},
	"navigation": {
		"tabs": [
			{
				"tab": "Documentation",
				"icon": "book-open",
				"groups": [
					{
						"group": "Get Started",
						"icon": "rocket-launch",
						"pages": ["introduction", "quickstart", "project-structure"]
					},
					{
						"group": "Core Concepts",
						"icon": "lightbulb",
						"pages": [
							"concepts/templating",
							"concepts/layouts-slots",
							"concepts/routing",
							"concepts/components",
							"concepts/scripts"
						]
					},
					{
						"group": "Data & Content",
						"icon": "brackets-curly",
						"pages": [
							"data/props",
							"data/content-collections",
							"data/environment-variables",
							"data/site-url"
						]
					},
					{
						"group": "Server & Interactivity",
						"icon": "server",
						"pages": ["server/nitro", "server/htmx-alpine", "server/middleware-redirects"]
					},
					{
						"group": "Configuration",
						"icon": "sliders-up",
						"pages": [
							"configuration/vite-plugin",
							"configuration/aero-config",
							"configuration/path-aliases",
							"configuration/typescript"
						]
					},
					{
						"group": "Tooling",
						"icon": "hammer-brush",
						"pages": [
							"tooling/cli",
							"tooling/vscode-extension",
							"tooling/incremental-builds",
							"tooling/image-optimization"
						]
					}
				]
			}
		]
	},
	"styling": {
		"codeblocks": {
			"theme": "github-dark-default"
		}
	},
	"appearance": {
		"default": "dark"
	},
	"background": {
		"color": {
			"dark": "#090d18",
			"light": "#fafafa"
		},
		"decoration": "gradient"
	},
	"description": "Build fast, HTML-first static sites and full-stack apps with a native web feel.",
	"favicon": "/images/favicon.ico",
	"logo": {
		"light": "/images/logo-light-mode.svg",
		"dark": "/images/logo-dark-mode.svg"
	}
}
