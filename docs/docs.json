{
	"$schema": "https://mintlify.com/docs.json",
	"name": "Aero",
	"theme": "maple",
	"colors": {
		"primary": "#fa8072",
		"light": "#fa8072",
		"dark": "#fa8072"
	},
	"icons": {
		"library": "lucide"
	},

	"navigation": {
		"tabs": [
			{
				"tab": "Get Started",
				"icon": "rocket",
				"pages": [
					"index",
					"getting-started/installation",
					"getting-started/structure",
					"getting-started/configuration",
					"getting-started/templates",
					"getting-started/routing",
					"getting-started/scripts",
					"getting-started/styling",
					"getting-started/assets",
					"getting-started/content",
					"getting-started/metadata",
					"getting-started/server",
					"getting-started/deployment"
				]
			},
			{
				"tab": "Guide",
				"icon": "book-open",
				"groups": [
					{
						"group": "Concepts",
						"icon": "lightbulb",
						"pages": ["guide/philosophy", "guide/html-template", "guide/learners-guide"]
					},
					{
						"group": "Practical guidance",
						"icon": "compass",
						"pages": [
							"guide/typescript",
							"guide/importing-and-bundling",
							"guide/dependency-policy",
							"guide/standalone-runtime"
						]
					}
				]
			},
			{
				"tab": "Tooling",
				"icon": "terminal",
				"pages": [
					"tooling/cli",
					"tooling/vscode-extension",
					"tooling/incremental-builds",
					"tooling/image-optimization"
				]
			},
			{
				"tab": "Examples",
				"icon": "app-window",
				"groups": [
					{
						"group": "Examples",
						"icon": "boxes",
						"pages": ["examples/index"]
					}
				]
			}
		]
	},
	"navbar": {
		"links": [
			{
				"label": "GitHub",
				"icon": "github",
				"href": "https://github.com/jamiewilson/aero"
			},
			{
				"label": "npm",
				"icon": "npm",
				"href": "https://www.npmjs.com/~aero-js"
			},
			{
				"label": "VS Code",
				"icon": "code",
				"href": "https://marketplace.visualstudio.com/items?itemName=aero-js.aero-vscode"
			}
		]
	},
	"styling": {
		"codeblocks": {
			"theme": "github-dark-default"
		}
	},
	"appearance": {
		"default": "dark"
	},
	"background": {
		"color": {
			"dark": "#090d18",
			"light": "#fafafa"
		},
		"decoration": "gradient"
	},
	"description": "Build fast, HTML-first static sites and full-stack apps with a native web feel.",
	"favicon": "/images/favicon.ico",
	"logo": {
		"light": "/images/logo-light-mode.svg",
		"dark": "/images/logo-dark-mode.svg"
	}
}
