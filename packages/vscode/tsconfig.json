{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"@aero-js/core/editor": ["../core/dist/entry-editor.d.mts"],
			"@aero-js/core/utils/aliases": ["../core/dist/utils/aliases.d.mts"]
		},
		"lib": ["ES2020"],
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"sourceMap": true,
		"types": ["node", "vscode"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "src/server.ts"]
}
