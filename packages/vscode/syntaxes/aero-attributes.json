{
	"scopeName": "aero.attributes.injection",
	"injectionSelector": "L:text.html.aero meta.tag -comment",
	"patterns": [
		{ "include": "#aero-script-type-attributes" },
		{ "include": "#aero-control-flow-attributes" },
		{ "include": "#aero-props-attribute" }
	],
	"repository": {
		"aero-script-type-attributes": {
			"comment": "Highlight is:build, is:inline, and is:blocking as special script type attributes",
			"match": "\\b(is:(build|inline|blocking))\\b",
			"captures": {
				"1": { "name": "entity.other.attribute-name.html" }
			}
		},
		"aero-control-flow-attributes": {
			"comment": "Highlight Aero control flow attributes (shorthand and data-* forms) with consistent styling. Matches the full attribute (name=value) so the base HTML grammar does not wrap data-* forms in meta.attribute.data-x.",
			"patterns": [
				{
					"comment": "Aero for / data-for with value",
					"begin": "\\b(data-for|for)(?=[\\s=/>])",
					"beginCaptures": {
						"1": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				},
				{
					"comment": "Aero if / data-if with value",
					"begin": "\\b(data-if|if)(?=[\\s=/>])",
					"beginCaptures": {
						"1": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				},
				{
					"comment": "Aero else-if / data-else-if with value",
					"begin": "\\b(data-else-if|else-if)(?=[\\s=/>])",
					"beginCaptures": {
						"1": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				},
				{
					"comment": "Aero else / data-else (valueless)",
					"match": "\\b(data-else|else)(?=[\\s/>])",
					"captures": {
						"1": { "name": "entity.other.attribute-name.html" }
					},
					"name": "meta.attribute.aero"
				}
			]
		},
		"aero-props-attribute": {
			"comment": "Highlight props and data-props attributes",
			"patterns": [
				{
					"begin": "\\b(data-props|props)(?=[\\s=/>])",
					"beginCaptures": {
						"1": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				}
			]
		},
		"aero-attribute-value": {
			"comment": "Matches the = and quoted value portion of an Aero attribute",
			"begin": "(=)\\s*",
			"beginCaptures": {
				"1": { "name": "punctuation.separator.key-value.html" }
			},
			"end": "(?<=[\"'])",
			"patterns": [
				{
					"begin": "(\")",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(\")",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"contentName": "string.quoted.double.html"
				},
				{
					"begin": "(')",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(')",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"contentName": "string.quoted.single.html"
				}
			]
		}
	}
}
