{
	"scopeName": "aero.attributes.injection",
	"injectionSelector": "R:text.html.basic meta.tag -comment -string, R:text.html meta.tag -comment -string",
	"patterns": [
		{ "include": "#aero-script-type-attributes" },
		{ "include": "#aero-control-flow-attributes" },
		{ "include": "#aero-props-attribute" }
	],
	"repository": {
		"aero-script-type-attributes": {
			"comment": "Highlight is:build/state/inline/blocking and aero-/data-aero- spellings as special script type attributes",
			"match": "\\b((?:data-aero-is-|aero-is[:\\-]|is:)(?:build|state|inline|blocking))\\b",
			"captures": {
				"1": { "name": "entity.other.attribute-name.html" }
			}
		},
		"aero-control-flow-attributes": {
			"comment": "Highlight Aero control flow attributes (bare, aero-*, and data-aero-* forms) with consistent styling.",
			"patterns": [
				{
					"comment": "Aero for with value",
					"begin": "\\b(?:(?:data-aero-|aero-)?for|for)(?=[\\s=/>])",
					"beginCaptures": {
						"0": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-for-attribute-value" }]
				},
				{
					"comment": "Aero if with value",
					"begin": "\\b(?:(?:data-aero-|aero-)?if|if)(?=[\\s=/>])",
					"beginCaptures": {
						"0": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				},
				{
					"comment": "Aero else-if with value",
					"begin": "\\b(?:(?:data-aero-|aero-)?else-if|else-if)(?=[\\s=/>])",
					"beginCaptures": {
						"0": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				},
				{
					"comment": "Aero else (valueless)",
					"match": "\\b(?:(?:data-aero-|aero-)?else|else)(?=[\\s/>])",
					"captures": {
						"0": { "name": "entity.other.attribute-name.html" }
					},
					"name": "meta.attribute.aero"
				}
			]
		},
		"aero-props-attribute": {
			"comment": "Highlight props and prefixed props attributes",
			"patterns": [
				{
					"begin": "\\b(?:(?:data-aero-|aero-)?props|props)(?=[\\s=/>])",
					"beginCaptures": {
						"0": { "name": "entity.other.attribute-name.html" }
					},
					"end": "(?=\\s|/?>)",
					"name": "meta.attribute.aero",
					"patterns": [{ "include": "#aero-attribute-value" }]
				}
			]
		},
		"aero-attribute-value": {
			"comment": "Matches the = and quoted value portion of an Aero attribute",
			"begin": "(=)\\s*",
			"beginCaptures": {
				"1": { "name": "punctuation.separator.key-value.html" }
			},
			"end": "(?<=[\"'])",
			"patterns": [
				{
					"begin": "(\")",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(\")",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"contentName": "string.quoted.double.html"
				},
				{
					"begin": "(')",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(')",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"contentName": "string.quoted.single.html"
				}
			]
		},
		"aero-for-attribute-value": {
			"comment": "for=\"{ const … of … }\" — for-of head highlighting (not bare source.ts block)",
			"begin": "(=)\\s*",
			"beginCaptures": {
				"1": { "name": "punctuation.separator.key-value.html" }
			},
			"end": "(?<=[\"'])",
			"patterns": [
				{
					"begin": "(\")",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(\")",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"patterns": [{ "include": "#aero-for-braced-value" }]
				},
				{
					"begin": "(')",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.string.begin.html" }
					},
					"end": "(')",
					"endCaptures": {
						"1": { "name": "punctuation.definition.string.end.html" }
					},
					"patterns": [{ "include": "#aero-for-braced-value" }]
				}
			]
		},
		"aero-for-braced-value": {
			"name": "meta.embedded.block.for-directive.aero",
			"begin": "(\\{)",
			"end": "(\\})",
			"beginCaptures": {
				"1": {
					"name": "punctuation.section.embedded.begin.aero punctuation.definition.string.begin.html"
				}
			},
			"endCaptures": {
				"1": {
					"name": "punctuation.section.embedded.end.aero punctuation.definition.string.end.html"
				}
			},
			"contentName": "meta.embedded.for-directive.aero source.ts",
			"patterns": [{ "include": "source.ts" }]
		}
	}
}
