{
	"scopeName": "text.html.aero",
	"name": "Aero HTML",
	"comment": "Extends HTML with script highlighting. Scripts with lang=\"ts\" or lang=\"typescript\" use TypeScript; others use JavaScript. Matches language-server extraction.",
	"patterns": [
		{ "include": "#aero-script" },
		{ "include": "text.html.basic" }
	],
	"repository": {
		"aero-script": {
			"patterns": [
				{
					"comment": "Script with lang=\"ts\" or lang=\"typescript\" → TypeScript",
					"name": "meta.embedded.block.ts.aero",
					"begin": "(?i)(<)(script)\\b(?=[^>]*\\blang\\s*=\\s*[\"'](?:ts|typescript)[\"'][^>]*>)",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [
								{ "include": "text.html.basic#attribute" }
							]
						},
						{
							"comment": "Script body as TypeScript",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.ts",
							"patterns": [
								{ "include": "source.ts" }
							]
						}
					]
				},
				{
					"comment": "Script without lang=\"ts\" → JavaScript",
					"name": "meta.embedded.block.js.aero",
					"begin": "(?i)(<)(script)\\b(?![^>]*\\blang\\s*=\\s*[\"'](?:ts|typescript)[\"'])",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [
								{ "include": "text.html.basic#attribute" }
							]
						},
						{
							"comment": "Script body as JavaScript",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.js",
							"patterns": [
								{ "include": "source.js" }
							]
						}
					]
				}
			]
		}
	}
}
