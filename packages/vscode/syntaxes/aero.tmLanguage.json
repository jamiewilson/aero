{
	"scopeName": "text.html.aero",
	"name": "Aero HTML",
	"comment": "Extends HTML with script highlighting. Lang ts/typescript → TS; importmap → JSON; is:build (no lang=js) → TS (default); other scripts → JS. Matches language-server virtualCode.",
	"patterns": [
		{ "include": "#aero-script" },
		{
			"comment": "Match <slot /> as self-closing so it gets void-tag scoping (ligature, bracket matching)",
			"begin": "(?i)(<)(slot)\\b(?=[^>]*\\/>)",
			"end": "(\\/>)",
			"name": "meta.tag.structure.slot.void.html",
			"beginCaptures": {
				"1": { "name": "punctuation.definition.tag.begin.html" },
				"2": { "name": "entity.name.tag.html" }
			},
			"endCaptures": {
				"1": { "name": "punctuation.definition.tag.end.html" }
			},
			"patterns": [{ "include": "text.html.basic#attribute" }]
		},
		{ "include": "text.html.basic" }
	],
	"repository": {
		"aero-script": {
			"patterns": [
				{
					"comment": "Script with lang=\"ts\" or lang=\"typescript\" → TypeScript",
					"name": "meta.embedded.block.ts.aero",
					"begin": "(?i)(<)(script)\\b(?=[^>]*\\blang\\s*=\\s*[\"'](?:ts|typescript)[\"'][^>]*>)",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [{ "include": "text.html.basic#attribute" }]
						},
						{
							"comment": "Script body as TypeScript",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.ts",
							"patterns": [{ "include": "source.ts" }]
						}
					]
				},
				{
					"comment": "Script with type=\"importmap\" → JSON (not JS/TS)",
					"name": "meta.embedded.block.importmap.aero",
					"begin": "(?i)(<)(script)\\b(?=[^>]*\\btype\\s*=\\s*[\"']importmap[\"'])",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [{ "include": "text.html.basic#attribute" }]
						},
						{
							"comment": "Import map body as JSON",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.json",
							"patterns": [{ "include": "source.json" }]
						}
					]
				},
				{
					"comment": "Build script without lang=\"js\" → TypeScript (is:build defaults to TS; lang=\"js\" opts out)",
					"name": "meta.embedded.block.ts.aero",
					"begin": "(?i)(<)(script)\\b(?=[^>]*\\bis:build\\b)(?![^>]*\\blang\\s*=\\s*[\"'](?:ts|typescript)[\"'])(?![^>]*\\blang\\s*=\\s*[\"'](?:js|javascript)[\"'])",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [{ "include": "text.html.basic#attribute" }]
						},
						{
							"comment": "Build script body as TypeScript",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.ts",
							"patterns": [{ "include": "source.ts" }]
						}
					]
				},
				{
					"comment": "Script without lang=\"ts\" and not is:build → JavaScript",
					"name": "meta.embedded.block.js.aero",
					"begin": "(?i)(<)(script)\\b(?![^>]*\\blang\\s*=\\s*[\"'](?:ts|typescript)[\"'])(?![^>]*\\btype\\s*=\\s*[\"']importmap[\"'])",
					"beginCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" }
					},
					"end": "(?i)(</)(script)\\s*(>)",
					"endCaptures": {
						"1": { "name": "punctuation.definition.tag.begin.html" },
						"2": { "name": "entity.name.tag.html" },
						"3": { "name": "punctuation.definition.tag.end.html" }
					},
					"patterns": [
						{
							"comment": "Opening tag attributes",
							"begin": "\\G",
							"end": "(>)",
							"endCaptures": {
								"1": { "name": "punctuation.definition.tag.end.html" }
							},
							"name": "meta.tag.metadata.script.start.html",
							"patterns": [{ "include": "text.html.basic#attribute" }]
						},
						{
							"comment": "Script body as JavaScript",
							"begin": "(?!\\G)",
							"end": "(?=</(?i:script))",
							"contentName": "source.js",
							"patterns": [{ "include": "source.js" }]
						}
					]
				}
			]
		}
	}
}
