{
	"name": "aero-vscode",
	"displayName": "Aero",
	"version": "0.3.5",
	"private": true,
	"description": "Language support for Aero templates in HTML",
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"aero",
		"aero-js",
		"completions",
		"framework",
		"highlight",
		"html",
		"snippets",
		"syntax",
		"template"
	],
	"bugs": {
		"url": "https://github.com/jamiewilson/aero/issues"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/vscode"
	},
	"publisher": "aero-js",
	"type": "module",
	"main": "./dist/extension.cjs",
	"scripts": {
		"dev": "tsdown --watch",
		"build": "pnpm --dir ../language-server exec npm run prebuild && tsdown --minify",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"vscode:prepublish": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aero-js/compiler": "workspace:*",
		"@aero-js/core": "workspace:*",
		"@aero-js/diagnostics": "workspace:*",
		"@aero-js/html-parser": "workspace:*",
		"@aero-js/interpolation": "workspace:*",
		"@volar/vscode": "~2.4.28",
		"jiti": "^2.6.1"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"@types/vscode": "^1.105.0",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"contributes": {
		"commands": [
			{
				"command": "aero.runCheck",
				"title": "Run check (config, content, templates)",
				"category": "Aero"
			}
		],
		"taskDefinitions": [
			{
				"type": "aero",
				"required": [
					"task"
				],
				"properties": {
					"task": {
						"type": "string",
						"enum": [
							"check"
						],
						"description": "Aero CLI task (e.g. check templates and content)"
					}
				}
			}
		],
		"languages": [
			{
				"id": "aero",
				"aliases": [
					"Aero",
					"Aero HTML"
				],
				"icon": {
					"light": "./images/html-icon.svg",
					"dark": "./images/html-icon.svg"
				},
				"configuration": "./language-configuration.json"
			}
		],
		"configuration": {
			"title": "Aero",
			"properties": {
				"aero.debug": {
					"type": "boolean",
					"default": false,
					"markdownDescription": "Enable Aero extension debug logs in the Output panel (Aero channel), including project detection and HTML→Aero language switching decisions."
				},
				"aero.diagnostics.regexUndefinedVariables": {
					"type": "boolean",
					"default": false,
					"markdownDescription": "When false (default), skip regex-based “undefined variable in `{ }`” diagnostics — rely on the Volar language server and `aero check --types` for expression typing. Enable only if you need the legacy heuristic without the LS."
				}
			}
		},
		"configurationDefaults": {
			"emmet.includeLanguages": {
				"aero": "html"
			}
		},
		"grammars": [
			{
				"language": "aero",
				"scopeName": "text.html.aero",
				"path": "./syntaxes/aero.tmLanguage.json",
				"embeddedLanguages": {
					"source.css": "css",
					"source.js": "javascript",
					"source.json": "json",
					"source.ts": "typescript",
					"meta.embedded.expression.aero source.ts": "typescript"
				}
			},
			{
				"path": "./syntaxes/aero-expressions.json",
				"scopeName": "aero.expressions.injection",
				"injectTo": [
					"text.html.aero"
				],
				"embeddedLanguages": {
					"meta.embedded.expression.aero source.ts": "typescript"
				}
			},
			{
				"path": "./syntaxes/aero-attributes.json",
				"scopeName": "aero.attributes.injection",
				"injectTo": [
					"text.html.aero"
				]
			},
			{
				"path": "./syntaxes/aero-globals.json",
				"scopeName": "aero.globals.injection",
				"injectTo": [
					"text.html.aero"
				]
			}
		]
	},
	"activationEvents": [
		"onLanguage:html"
	],
	"icon": "images/logo.png",
	"engines": {
		"vscode": "^1.105.0"
	}
}
