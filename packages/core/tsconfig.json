{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"skipLibCheck": true,
		"types": ["node", "vite/client"],
		"paths": {
			"/@vite/client": ["./src/vite-client-shim.ts"]
		},
		"noEmit": true
	},
	"include": ["src/**/*.ts"]
}
