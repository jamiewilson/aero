{
	"name": "@aero-js/core",
	"version": "0.4.0",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/core"
	},
	"files": [
		"dist",
		"env.d.ts"
	],
	"type": "module",
	"types": "./dist/entry-dev.d.mts",
	"exports": {
		".": {
			"types": "./dist/entry-dev.d.mts",
			"default": "./dist/entry-dev.mjs"
		},
		"./entry-prod": {
			"types": "./dist/entry-prod.d.mts",
			"default": "./dist/entry-prod.mjs"
		},
		"./vite": {
			"types": "./dist/vite/index.d.mts",
			"default": "./dist/vite/index.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime/index.d.mts",
			"default": "./dist/runtime/index.mjs"
		},
		"./runtime/standalone": {
			"types": "./dist/runtime/standalone.d.mts",
			"default": "./dist/runtime/standalone.mjs"
		},
		"./runtime/fragment": {
			"types": "./dist/runtime/fragment.d.mts",
			"default": "./dist/runtime/fragment.mjs"
		},
		"./runtime/instance": {
			"types": "./dist/runtime/instance.d.mts",
			"default": "./dist/runtime/instance.mjs"
		},
		"./types": "./dist/types.d.mts",
		"./utils/aliases": {
			"types": "./dist/utils/aliases.d.mts",
			"default": "./dist/utils/aliases.mjs"
		},
		"./utils/aero-config": {
			"types": "./dist/utils/aero-config.d.mts",
			"default": "./dist/utils/aero-config.mjs"
		},
		"./utils/load-project-module": {
			"types": "./dist/utils/load-project-module.d.mts",
			"default": "./dist/utils/load-project-module.mjs"
		},
		"./utils/redirects": {
			"types": "./dist/utils/redirects.d.mts",
			"default": "./dist/utils/redirects.mjs"
		},
		"./editor": {
			"types": "./dist/entry-editor.d.mts",
			"default": "./dist/entry-editor.mjs"
		},
		"./template-diagnostics": {
			"types": "./dist/template-diagnostics-api.d.mts",
			"default": "./dist/template-diagnostics-api.mjs"
		},
		"./compile-check": {
			"types": "./dist/compile-check-api.d.mts",
			"default": "./dist/compile-check-api.mjs"
		},
		"./routing/route-manifest": {
			"types": "./dist/routing/route-manifest.d.mts",
			"default": "./dist/routing/route-manifest.mjs"
		},
		"./routing/route-typegen": {
			"types": "./dist/routing/route-typegen.d.mts",
			"default": "./dist/routing/route-typegen.mjs"
		},
		"./env": "./env.d.ts"
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepack": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aero-js/compiler": "workspace:*",
		"@aero-js/diagnostics": "workspace:*",
		"@aero-js/html-parser": "workspace:*",
		"@aero-js/hypermedia": "workspace:*",
		"@aero-js/interpolation": "workspace:*",
		"@aero-js/reactivity": "workspace:*",
		"get-tsconfig": "^4.14.0",
		"html-minifier-next": "^7.0.0",
		"jiti": "^2.7.0",
		"linkedom": "^0.18.12",
		"nitro": "catalog:",
		"oxc-resolver": "^11.21.3",
		"sharp": "^0.35.2",
		"svgo": "^4.0.1",
		"vite-plugin-image-optimizer": "^2.0.3"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"vite": "^8.1.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	}
}
