{
	"name": "@aero-js/core",
	"version": "0.3.5",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/core"
	},
	"files": [
		"dist",
		"env.d.ts"
	],
	"type": "module",
	"types": "./dist/entry-dev.d.mts",
	"exports": {
		".": {
			"types": "./dist/entry-dev.d.mts",
			"default": "./dist/entry-dev.mjs"
		},
		"./entry-prod": {
			"types": "./dist/entry-prod.d.mts",
			"default": "./dist/entry-prod.mjs"
		},
		"./vite": {
			"types": "./dist/vite/index.d.mts",
			"default": "./dist/vite/index.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime/index.d.mts",
			"default": "./dist/runtime/index.mjs"
		},
		"./runtime/instance": {
			"types": "./dist/runtime/instance.d.mts",
			"default": "./dist/runtime/instance.mjs"
		},
		"./types": "./dist/types.d.mts",
		"./utils/aliases": {
			"types": "./dist/utils/aliases.d.mts",
			"default": "./dist/utils/aliases.mjs"
		},
		"./utils/redirects": {
			"types": "./dist/utils/redirects.d.mts",
			"default": "./dist/utils/redirects.mjs"
		},
		"./editor": {
			"types": "./dist/entry-editor.d.mts",
			"default": "./dist/entry-editor.mjs"
		},
		"./diagnostics": {
			"types": "./dist/diagnostics.d.mts",
			"default": "./dist/diagnostics.mjs"
		},
		"./compile-check": {
			"types": "./dist/compile-check-api.d.mts",
			"default": "./dist/compile-check-api.mjs"
		},
		"./env": "./env.d.ts"
	},
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepack": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aero-js/diagnostics": "workspace:*",
		"@aero-js/interpolation": "workspace:*",
		"effect": "^3.20.0",
		"get-tsconfig": "^4.13.6",
		"html-minifier-next": "^5.1.1",
		"linkedom": "^0.18.12",
		"nitro": "^3.0.1-alpha.2",
		"oxc-parser": "^0.115.0",
		"oxc-resolver": "^11.19.0",
		"oxc-transform": "^0.116.0",
		"sharp": "^0.34.5",
		"svgo": "^4.0.0",
		"vite-plugin-image-optimizer": "^2.0.3"
	},
	"devDependencies": {
		"@types/node": "^25.3.0",
		"tsdown": "^0.21.0-beta.2",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18"
	},
	"peerDependencies": {
		"vite": "^8.0.0-0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	}
}
