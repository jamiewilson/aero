{
	"name": "@aero-js/highlight",
	"version": "0.3.5",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/highlight"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
