		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@shikijs/transformers": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"@shikijs/transformers": {
			"optional": true
		}
	}
