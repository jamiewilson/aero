{
	"name": "@aero-js/config",
	"version": "0.3.5",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/config"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./vite": {
			"types": "./dist/vite.d.mts",
			"default": "./dist/vite.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts src/vite.ts --format esm --dts --clean --out-dir dist",
		"typecheck": "tsc --noEmit",
		"prepack": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aero-js/core": "workspace:*",
		"@aero-js/vite": "workspace:*",
		"effect": "^3.21.0",
		"jiti": "^2.6.1"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"@aero-js/content": "workspace:*",
		"@aero-js/core": "workspace:*",
		"vite": "8.0.3"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	}
}
