{
	"name": "@aero-js/config",
	"version": "0.4.0",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/config"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./vite": {
			"types": "./dist/vite.d.mts",
			"default": "./dist/vite.mjs"
		},
		"./analyzer-entries": {
			"types": "./dist/analyzer-entries.d.mts",
			"default": "./dist/analyzer-entries.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts src/vite.ts src/analyzer-entries.ts --format esm --dts --clean --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"prepack": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aero-js/core": "workspace:*",
		"@aero-js/vite": "workspace:*",
		"jiti": "^2.7.0"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"@aero-js/content": "workspace:*",
		"@aero-js/core": "workspace:*",
		"vite": "^8.1.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	}
}
