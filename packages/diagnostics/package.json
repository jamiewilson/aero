{
	"name": "@aero-js/diagnostics",
	"version": "0.4.0",
	"private": false,
	"homepage": "https://github.com/jamiewilson/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/diagnostics"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		},
		"./browser": {
			"types": "./dist/browser.d.mts",
			"default": "./dist/browser.mjs"
		},
		"./ide-catalog": {
			"types": "./dist/ide-catalog.d.mts",
			"default": "./dist/ide-catalog.mjs"
		},
		"./parity": {
			"types": "./dist/parity/index.d.mts",
			"default": "./dist/parity/index.mjs"
		}
	},
	"scripts": {
		"gen-templates": "node scripts/embed-templates.mjs",
		"compile": "tsdown src/index.ts src/browser.ts src/ide-catalog.ts src/parity/index.ts --format esm --dts --clean --out-dir dist",
		"embed-templates": "pnpm gen-templates && pnpm compile",
		"build": "pnpm embed-templates",
		"typecheck": "pnpm gen-templates && tsc --noEmit",
		"test": "pnpm gen-templates && vitest run",
		"prepack": "cp ../../LICENSE ."
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"vite": "^8.1.0"
	},
	"peerDependenciesMeta": {
		"vite": {
			"optional": true
		}
	}
}
