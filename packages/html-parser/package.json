{
	"name": "@aero-js/html-parser",
	"version": "0.3.5",
	"private": false,
	"description": "Minimal vscode-html-languageservice parser wrapper for Aero tooling (LS + VS Code)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/jamiewilson/aero.git",
		"directory": "packages/html-parser"
	},
	"files": ["dist"],
	"type": "module",
	"main": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/index.ts --format esm --dts --clean --out-dir dist",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"vscode-html-languageservice": "^5.6.2",
		"vscode-languageserver-textdocument": "^1.0.12"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3",
		"vitest": "^4.1.1"
	}
}
