{
	"name": "aerobuilt",
	"version": "0.3.2",
	"homepage": "https://github.com/aerobuilt/aero",
	"license": "MIT",
	"author": "Jamie Wilson",
	"repository": {
		"type": "git",
		"url": "https://github.com/aerobuilt/aero.git",
		"directory": "packages/aerobuilt"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/client.d.mts",
			"default": "./dist/client.mjs"
		},
		"./config": {
			"types": "./dist/config.d.mts",
			"default": "./dist/config.mjs"
		},
		"./content": {
			"types": "./dist/content.d.mts",
			"default": "./dist/content.mjs"
		},
		"./runtime": {
			"types": "./dist/runtime.d.mts",
			"default": "./dist/runtime.mjs"
		},
		"./vite": {
			"types": "./dist/vite.d.mts",
			"default": "./dist/vite.mjs"
		}
	},
	"scripts": {
		"build": "tsdown src/client.ts src/config.ts src/content.ts src/runtime.ts src/vite.ts --format esm --dts --clean --out-dir dist --minify",
		"prepack": "cp ../../LICENSE ."
	},
	"dependencies": {
		"@aerobuilt/config": "workspace:*",
		"@aerobuilt/content": "workspace:*",
		"@aerobuilt/core": "workspace:*"
	},
	"devDependencies": {
		"tsdown": "^0.21.0-beta.2",
		"typescript": "^5.9.3"
	}
}
