{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node", "@playwright/test"],
		"strict": true,
		"noEmit": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true
	},
	"include": ["playwright.config.ts", "tests/e2e/**/*.ts"]
}
