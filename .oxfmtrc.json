{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"semi": false,
	"useTabs": true,
	"tabWidth": 2,
	"singleQuote": true,
	"arrowParens": "avoid",
	"bracketSameLine": true,
	"bracketSpacing": true,
	"singleAttributePerLine": false,
	"trailingComma": "es5",
	"ignorePatterns": ["Base.astro", ".cursor/**/*", ".gemini/**/*", ".agent/**/*"]
}
