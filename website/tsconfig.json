{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["vite/client"],
		"baseUrl": "./",
		"paths": {
			"@layouts/*": ["./client/layouts/*"],
			"@components/*": ["./client/components/*"],
			"@styles/*": ["./client/assets/styles/*"],
			"@scripts/*": ["./client/assets/scripts/*"],
			"@content/*": ["./content/*"]
		}
	}
}
