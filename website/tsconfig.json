{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["@aero-js/core/env", "vite/client"],
		"paths": {
			"@layouts/*": ["./client/layouts/*"],
			"@components/*": ["./client/components/*"],
			"@styles/*": ["./client/assets/styles/*"],
			"@scripts/*": ["./client/assets/scripts/*"],
			"@content/*": ["./content/*"]
		}
	}
}
