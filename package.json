{
	"name": "aero",
	"private": true,
	"type": "module",
	"scripts": {
		"format": "oxfmt",
		"dev": "pnpm --dir examples/kitchen-sink dev",
		"preview": "pnpm --dir examples/kitchen-sink preview",
		"test": "vitest run",
		"test:ui": "pnpm vitest --ui",
		"test:e2e:install": "playwright install chromium",
		"test:e2e:ci": "playwright test",
		"test:e2e": "node scripts/run-playwright-local.js test",
		"test:e2e:headed": "node scripts/run-playwright-local.js test --headed",
		"test:e2e:debug": "node scripts/run-playwright-local.js test --debug",
		"test:all": "pnpm typecheck && pnpm test && pnpm test:e2e:ci",
		"typecheck": "pnpm -r typecheck",
		"build": "pnpm -r --filter @aero-js/interpolation --filter @aero-js/html-parser --filter @aero-js/highlight --filter @aero-js/diagnostics --filter @aero-js/compiler --filter @aero-js/core --filter @aero-js/vite --filter @aero-js/content --filter @aero-js/config --filter @aero-js/cli --filter @aero-js/create run build",
		"build:interpolation": "pnpm --dir packages/interpolation build",
		"build:highlight": "pnpm --dir packages/highlight build",
		"build:core": "pnpm --dir packages/core build",
		"build:content": "pnpm --dir packages/content build",
		"build:config": "pnpm --dir packages/config build",
		"build:vite": "pnpm --dir packages/vite build",
		"build:vscode": "pnpm --dir packages/vscode build",
		"build:website": "pnpm build && pnpm --filter aero-website build",
		"vscode:package": "pnpm build:vscode && pnpm --dir packages/vscode exec vsce package --no-dependencies",
		"clean:all": "rm -rf node_modules && find packages examples -type d \\( -name node_modules -o -name dist -o -name build -o -name .output -o -name .aero \\) -prune -exec rm -rf {} +",
		"version:bump": "node scripts/bump-versions.js",
		"release:prep": "pnpm test && pnpm clean:all && pnpm install && pnpm build",
		"release:publish": "pnpm -r publish"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.0",
		"@types/node": "catalog:",
		"@vitest/ui": "4.1.2",
		"oxfmt": "^0.43.0",
		"vitest": "catalog:"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"brace-expansion": ">=2.0.3",
			"nitro": "3.0.260311-beta",
			"vite": "8.0.3"
		}
	}
}
