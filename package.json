{
	"name": "aero",
	"private": true,
	"type": "module",
	"scripts": {
		"fmt": "pnpm exec vp fmt",
		"check": "pnpm exec vp check",
		"lint": "pnpm exec vp lint",
		"dev": "pnpm --dir examples/kitchen-sink exec vp dev",
		"preview": "pnpm --dir examples/kitchen-sink exec vp preview",
		"test": "pnpm typecheck && pnpm exec vp test",
		"typecheck": "pnpm exec vp run typecheck:workspace",
		"build": "pnpm exec vp run build:packages",
		"build:interpolation": "pnpm --dir packages/interpolation build",
		"build:highlight": "pnpm --dir packages/highlight build",
		"build:core": "pnpm --dir packages/core build",
		"build:content": "pnpm --dir packages/content build",
		"build:config": "pnpm --dir packages/config build",
		"build:vite": "pnpm --dir packages/vite build",
		"build:vscode": "pnpm --dir packages/vscode build",
		"build:website": "pnpm build && pnpm --filter aero-website build",
		"vscode:package": "pnpm build:vscode && pnpm --dir packages/vscode exec vsce package --no-dependencies",
		"clean:all": "rm -rf node_modules && find packages examples -type d \\( -name node_modules -o -name dist -o -name build -o -name .output -o -name .aero \\) -prune -exec rm -rf {} +",
		"version:bump": "node scripts/bump-versions.js",
		"release:prep": "pnpm test && pnpm clean:all && pnpm install && pnpm build",
		"release:publish": "pnpm -r publish"
	},
	"devDependencies": {
		"vite-plus": "0.1.14",
		"vitest": "^4.1.1"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"peerDependencyRules": {
			"allowAny": [
				"vite",
				"vitest"
			]
		},
		"overrides": {
			"vite": "npm:@voidzero-dev/vite-plus-core@0.1.14",
			"vitest": "npm:@voidzero-dev/vite-plus-test@0.1.14"
		}
	}
}
